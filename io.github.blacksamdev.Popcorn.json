{
  "app-id": "io.github.blacksamdev.Popcorn",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "bbs-popcorn",

  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=xdg-config",
    "--filesystem=xdg-cache",
    "--filesystem=xdg-data"
  ],

  "modules": [

    {
      "name": "mpv",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/mpv-player/mpv/archive/v0.38.0.tar.gz",
          "sha256": "86d9ef40b6058732f67b46d0bbda24a074fae860b3eaae05bab3145041303066"
        }
      ]
    },

    {
      "name": "yt-dlp",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 yt-dlp /app/bin/yt-dlp"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp",
          "sha256": "REPLACE_WITH_SHA256"
        }
      ]
    },

    {
      "name": "bbs-popcorn",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 bbs-popcorn.sh /app/bin/bbs-popcorn",

        "install -Dm644 src/bbs_popcorn/main.py /app/lib/bbs-popcorn/main.py",
        "install -Dm644 src/bbs_popcorn/app.py /app/lib/bbs-popcorn/app.py",
        "install -Dm644 src/bbs_popcorn/player.py /app/lib/bbs-popcorn/player.py",
        "install -Dm644 src/bbs_popcorn/cookies.py /app/lib/bbs-popcorn/cookies.py",
        "install -Dm644 src/bbs_popcorn/updater.py /app/lib/bbs-popcorn/updater.py",

        "install -Dm644 data/io.github.blacksamdev.Popcorn.desktop /app/share/applications/io.github.blacksamdev.Popcorn.desktop",
        "install -Dm644 data/io.github.blacksamdev.Popcorn.svg /app/share/icons/hicolor/scalable/apps/io.github.blacksamdev.Popcorn.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
