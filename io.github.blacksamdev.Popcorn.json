{
  "app-id": "io.github.blacksamdev.Popcorn",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "bbs-popcorn",

  "modules": [
    {
      "name": "yt-dlp",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 yt-dlp /app/bin/yt-dlp"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp",
          "sha256": "3bda0968a01cde70d26720653003b28553c71be14dcb2e5f4c24e9921fdad745"
        }
      ]
    },

    {
      "name": "popcorn",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 wrapper.sh /app/bin/bbs-popcorn",
        "install -Dm755 src/bbs_popcorn/main.py /app/bin/main.py",
        "install -Dm755 src/bbs_popcorn/updater.py /app/bin/updater.py"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
