{
  "app-id": "io.github.blacksamdev.Popcorn",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "bbs-popcorn",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=xdg-config/bbs-popcorn:create",
    "--filesystem=~/.var/app/io.mpv.Mpv/config/mpv/scripts:create",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.secrets"
  ],

  "modules": [
    {
      "name": "yt-dlp",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 yt-dlp.sh /app/bin/yt-dlp"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/yt-dlp/yt-dlp.git",
          "tag": "2026.03.17"
        }
      ]
    },
    {
      "name": "sponsorblock-script",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 sponsorblock.lua /app/share/bbs-popcorn/sponsorblock.lua",
        "install -Dm644 main.lua /app/share/bbs-popcorn/sponsorblock_shared/main.lua",
        "install -Dm644 sponsorblock.py /app/share/bbs-popcorn/sponsorblock_shared/sponsorblock.py"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/po5/mpv_sponsorblock/master/sponsorblock.lua",
          "sha256": "2926efc61866ff784cfd6c5753eb4d88382d395f0af8062aea834eb772589ba4"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/po5/mpv_sponsorblock/master/sponsorblock_shared/main.lua",
          "sha256": "d00c0438ab63c106807802628e51f0a41859c1173dc88350a4efd5e3892bf7f6"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/po5/mpv_sponsorblock/master/sponsorblock_shared/sponsorblock.py",
          "sha256": "bb050852a857e11f6ca4efeb84748e431711fd90fc118f081db1ee54b5f4f263"
        }
      ]
    },
    {
      "name": "popcorn",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 wrapper.sh /app/bin/bbs-popcorn",
        "mkdir -p /app/lib/bbs-popcorn/bbs_popcorn",
        "install -Dm644 src/bbs_popcorn/__init__.py /app/lib/bbs-popcorn/bbs_popcorn/__init__.py",
        "install -Dm644 src/bbs_popcorn/main.py /app/lib/bbs-popcorn/bbs_popcorn/main.py",
        "install -Dm644 src/bbs_popcorn/app.py /app/lib/bbs-popcorn/bbs_popcorn/app.py",
        "install -Dm644 src/bbs_popcorn/player.py /app/lib/bbs-popcorn/bbs_popcorn/player.py",
        "install -Dm644 src/bbs_popcorn/updater.py /app/lib/bbs-popcorn/bbs_popcorn/updater.py",
        "install -Dm644 src/bbs_popcorn/cookies.py /app/lib/bbs-popcorn/bbs_popcorn/cookies.py",
        "install -Dm644 src/bbs_popcorn/logging_utils.py /app/lib/bbs-popcorn/bbs_popcorn/logging_utils.py",
        "install -Dm644 src/bbs_popcorn/resume_store.py /app/lib/bbs-popcorn/bbs_popcorn/resume_store.py",
        "install -Dm644 src/bbs_popcorn/history_store.py /app/lib/bbs-popcorn/bbs_popcorn/history_store.py",
        "install -Dm644 data/io.github.blacksamdev.Popcorn.desktop /app/share/applications/io.github.blacksamdev.Popcorn.desktop",
        "install -Dm644 data/io.github.blacksamdev.Popcorn.svg /app/share/icons/hicolor/scalable/apps/io.github.blacksamdev.Popcorn.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
