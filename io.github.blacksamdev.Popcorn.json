{
  "app-id": "io.github.blacksamdev.Popcorn",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "bbs-popcorn",

  "finish-args": [
    "--share=network",
    "--filesystem=home"
  ],

  "modules": [
    {
      "name": "popcorn",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 src/bbs_popcorn/main.py /app/bin/bbs-popcorn",
        "install -Dm755 src/bbs_popcorn/updater.py /app/bin/updater.py"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
