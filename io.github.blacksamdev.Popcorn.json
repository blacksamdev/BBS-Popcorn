{
  "app-id": "io.github.blacksamdev.Popcorn",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "bbs-popcorn",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--filesystem=xdg-config/bbs-popcorn:create",
    "--talk-name=org.freedesktop.Flatpak"
  ],

  "modules": [
    {
      "name": "yt-dlp",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 yt-dlp.sh /app/bin/yt-dlp"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/yt-dlp/yt-dlp.git",
          "branch": "master"
        }
      ]
    },
    {
      "name": "popcorn",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 wrapper.sh /app/bin/bbs-popcorn",
        "mkdir -p /app/lib/bbs-popcorn/bbs_popcorn",
        "install -Dm644 src/bbs_popcorn/__init__.py /app/lib/bbs-popcorn/bbs_popcorn/__init__.py",
        "install -Dm644 src/bbs_popcorn/main.py /app/lib/bbs-popcorn/bbs_popcorn/main.py",
        "install -Dm644 src/bbs_popcorn/app.py /app/lib/bbs-popcorn/bbs_popcorn/app.py",
        "install -Dm644 src/bbs_popcorn/player.py /app/lib/bbs-popcorn/bbs_popcorn/player.py",
        "install -Dm644 src/bbs_popcorn/updater.py /app/lib/bbs-popcorn/bbs_popcorn/updater.py",
        "install -Dm644 src/bbs_popcorn/cookies.py /app/lib/bbs-popcorn/bbs_popcorn/cookies.py",
        "install -Dm644 data/io.github.blacksamdev.Popcorn.desktop /app/share/applications/io.github.blacksamdev.Popcorn.desktop",
        "install -Dm644 data/io.github.blacksamdev.Popcorn.svg /app/share/icons/hicolor/scalable/apps/io.github.blacksamdev.Popcorn.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
